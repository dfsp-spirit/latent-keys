            </MouseComponent>
            <KeyboardComponent name="mri_keys" plugin="None">
                <Param name="name" val="mri_keys" valType="code" updates="None" plugin="None"/>
                <Param name="startVal" val="0" valType="code" updates="None" plugin="None"/>
                <Param name="startEstim" val="" valType="code" updates="None" plugin="None"/>
                <Param name="startType" val="time (s)" valType="str" updates="None" plugin="None"/>
                <Param name="stopVal" val="10" valType="code" updates="constant" plugin="None"/>
                <Param name="durationEstim" val="" valType="code" updates="None" plugin="None"/>
                <Param name="stopType" val="duration (s)" valType="str" updates="None" plugin="None"/>
                <Param name="forceEndRoutine" val="False" valType="bool" updates="constant" plugin="None"/>
                <Param name="registerOn" val="press" valType="str" updates="constant" plugin="None"/>
                <Param name="allowedKeys" val="'1', '2', '3', '4', '6', '7', '8', '9'" valType="list" updates="constant" plugin="None"/>
                <Param name="store" val="last key" valType="str" updates="constant" plugin="None"/>
                <Param name="storeCorrect" val="False" valType="bool" updates="constant" plugin="None"/>
                <Param name="correctAns" val="" valType="str" updates="constant" plugin="None"/>
                <Param name="saveStartStop" val="True" valType="bool" updates="None" plugin="None"/>
                <Param name="syncScreenRefresh" val="True" valType="bool" updates="constant" plugin="None"/>
                <Param name="disabled" val="False" valType="bool" updates="None" plugin="None"/>
                <Param name="discard previous" val="True" valType="bool" updates="constant" plugin="None"/>
            </KeyboardComponent>
            <CodeComponent name="task_trial_logic" plugin="None">
                <Param name="name" val="task_trial_logic" valType="code" updates="None" plugin="None"/>
                <Param name="Code Type" val="Auto-&gt;JS" valType="str" updates="None" plugin="None"/>
                <Param name="disabled" val="False" valType="bool" updates="None" plugin="None"/>
                <Param name="Before Experiment" val="" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Begin Experiment" val="# Maximum items allowed to be chosen simultaneously&#10;NUM_ITEMS_TO_SELECT = 3&#10;&#10;# max number of keys, the present hardware keys on the MRI button box&#10;MASTER_KEYS = ['1', '2', '3', '4', '6', '7', '8', '9']&#10;&#10;NUM_BUTTONS = 8 # Allow using only a subset of buttons, up to len(MASTER_KEYS)&#10;&#10;&#10;# Dynamically slice the keys to match the number of active buttons&#10;ACTIVE_KEYS = MASTER_KEYS[:NUM_BUTTONS]&#10;&#10;# Dynamically build the dictionary mapping key strings back to indices (0 to NUM_BUTTONS-1)&#10;key_map = {}&#10;for idx in range(len(ACTIVE_KEYS)):&#10;    key = ACTIVE_KEYS[idx]&#10;    key_map[key] = idx&#10;&#10;# File paths to transparent symbol files&#10;symbol_files = [&#10;    'assets/sym1.png', 'assets/sym2.png', 'assets/sym3.png', 'assets/sym4.png', &#10;    'assets/sym5.png', 'assets/sym6.png', 'assets/sym7.png', 'assets/sym8.png'&#10;]&#10;&#10;# Calculate flat horizontal spacing for 8 buttons across screen width&#10;# In 'height' units, a normal 16:9 screen width is roughly -0.8 to +0.8&#10;button_positions = []&#10;start_x = -0.5&#10;spacing_x = 0.15&#10;button_position_y = -0.4&#10;for i in range(NUM_BUTTONS):&#10;    button_positions.append((start_x + (i * spacing_x), button_position_y))&#10;&#10;border_objects = [button_border_0, button_border_1, button_border_2, button_border_3, button_border_4, button_border_5, button_border_6, button_border_7]&#10;button_objects = [button_0, button_1, button_2, button_3, button_4, button_5, button_6, button_7]&#10;center_overlays = [center_0, center_1, center_2]" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Begin Routine" val="active_selections = [0] * NUM_BUTTONS&#10;&#10;# safeguard flag to prevent a single continuous mouse click from toggling a button 60 times a second&#10;mouse_was_pressed = False" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Each Frame" val="# 1. HANDLE INPUT DETECTION (Desktop Mouse vs Scanner Buttons)&#10;current_click_detected = False&#10;clicked_idx = -1&#10;&#10;# Check for fMRI button-box inputs&#10;keys = mri_keys.getKeys(keyList=ACTIVE_KEYS, waitRelease=False)&#10;if len(keys) &gt; 0:&#10;    clicked_idx = key_map[keys[0].name]&#10;    current_click_detected = True&#10;&#10;# Check for Web/Desktop mouse inputs&#10;else:&#10;    mouse_buttons = mouse.getPressed()&#10;    if mouse_buttons[0] == 1: # Left mouse button down&#10;        if not mouse_was_pressed: # Only trigger on the initial click frame&#10;            mouse_was_pressed = True&#10;            # Check which specific button shape boundary the cursor is inside&#10;            for i in range(NUM_BUTTONS):&#10;                if mouse.isPressedIn(button_objects[i]):&#10;                    clicked_idx = i&#10;                    current_click_detected = True&#10;    else:&#10;        mouse_was_pressed = False&#10;&#10;# 2. EVALUATE SELECTION MUTATION RULE&#10;if current_click_detected and clicked_idx != -1:&#10;    if active_selections[clicked_idx] == 1:&#10;        # Item is currently active: safely deselect it&#10;        active_selections[clicked_idx] = 0&#10;    else:&#10;        # Item is inactive: verify we haven't crossed threshold N before turning on&#10;        if sum(active_selections) &lt; NUM_ITEMS_TO_SELECT:&#10;            active_selections[clicked_idx] = 1&#10;&#10;# 3. DYNAMICALLY RENDER VISUAL PROPERTIES BASED ON RUNTIME STATE&#10;active_count = 0&#10;for i in range(NUM_BUTTONS):&#10;    if active_selections[i] == 1:&#10;        # Highlight outline (increase visual border thickness/contrast)&#10;        border_objects[i].setLineWidth(6)&#10;        border_objects[i].setLineColor('white')&#10;        &#10;        # Draw selected components mapped onto the giant center stacking zones&#10;        center_overlays[active_count].setImage(symbol_files[i])&#10;        center_overlays[active_count].setOpacity(0.8) # Blend textures transparently&#10;        active_count += 1&#10;    else:&#10;        # Default state properties&#10;        border_objects[i].setLineWidth(2)&#10;        border_objects[i].setLineColor('gray')&#10;&#10;# Hide any remaining center stacking placeholders not currently used&#10;for j in range(active_count, NUM_ITEMS_TO_SELECT):&#10;    center_overlays[j].setOpacity(0.0)" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="End Routine" val="" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="End Experiment" val="" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Before JS Experiment" val="" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Begin JS Experiment" val="NUM_ITEMS_TO_SELECT = 3;&#10;MASTER_KEYS = [&quot;1&quot;, &quot;2&quot;, &quot;3&quot;, &quot;4&quot;, &quot;6&quot;, &quot;7&quot;, &quot;8&quot;, &quot;9&quot;];&#10;NUM_BUTTONS = 8;&#10;ACTIVE_KEYS = MASTER_KEYS.slice(0, NUM_BUTTONS);&#10;key_map = {};&#10;for (var idx, _pj_c = 0, _pj_a = util.range(ACTIVE_KEYS.length), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&#10;    idx = _pj_a[_pj_c];&#10;    key = ACTIVE_KEYS[idx];&#10;    key_map[key] = idx;&#10;}&#10;symbol_files = [&quot;assets/sym1.png&quot;, &quot;assets/sym2.png&quot;, &quot;assets/sym3.png&quot;, &quot;assets/sym4.png&quot;, &quot;assets/sym5.png&quot;, &quot;assets/sym6.png&quot;, &quot;assets/sym7.png&quot;, &quot;assets/sym8.png&quot;];&#10;button_positions = [];&#10;start_x = (- 0.5);&#10;spacing_x = 0.15;&#10;button_position_y = (- 0.4);&#10;for (var i, _pj_c = 0, _pj_a = util.range(NUM_BUTTONS), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&#10;    i = _pj_a[_pj_c];&#10;    button_positions.push([(start_x + (i * spacing_x)), button_position_y]);&#10;}&#10;border_objects = [button_border_0, button_border_1, button_border_2, button_border_3, button_border_4, button_border_5, button_border_6, button_border_7];&#10;button_objects = [button_0, button_1, button_2, button_3, button_4, button_5, button_6, button_7];&#10;center_overlays = [center_0, center_1, center_2];&#10;" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Begin JS Routine" val="active_selections = ([0] * NUM_BUTTONS);&#10;mouse_was_pressed = false;&#10;" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="Each JS Frame" val="current_click_detected = false;&#10;clicked_idx = (- 1);&#10;keys = mri_keys.getKeys({&quot;keyList&quot;: ACTIVE_KEYS, &quot;waitRelease&quot;: false});&#10;if ((keys.length &gt; 0)) {&#10;    clicked_idx = key_map[keys[0].name];&#10;    current_click_detected = true;&#10;} else {&#10;    mouse_buttons = mouse.getPressed();&#10;    if ((mouse_buttons[0] === 1)) {&#10;        if ((! mouse_was_pressed)) {&#10;            mouse_was_pressed = true;&#10;            for (var i, _pj_c = 0, _pj_a = util.range(NUM_BUTTONS), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&#10;                i = _pj_a[_pj_c];&#10;                if (mouse.isPressedIn(button_objects[i])) {&#10;                    clicked_idx = i;&#10;                    current_click_detected = true;&#10;                }&#10;            }&#10;        }&#10;    } else {&#10;        mouse_was_pressed = false;&#10;    }&#10;}&#10;if ((current_click_detected &amp;&amp; (clicked_idx !== (- 1)))) {&#10;    if ((active_selections[clicked_idx] === 1)) {&#10;        active_selections[clicked_idx] = 0;&#10;    } else {&#10;        if ((util.sum(active_selections) &lt; NUM_ITEMS_TO_SELECT)) {&#10;            active_selections[clicked_idx] = 1;&#10;        }&#10;    }&#10;}&#10;active_count = 0;&#10;for (var i, _pj_c = 0, _pj_a = util.range(NUM_BUTTONS), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&#10;    i = _pj_a[_pj_c];&#10;    if ((active_selections[i] === 1)) {&#10;        border_objects[i].setLineWidth(6);&#10;        border_objects[i].setLineColor(&quot;white&quot;);&#10;        center_overlays[active_count].setImage(symbol_files[i]);&#10;        center_overlays[active_count].setOpacity(0.8);&#10;        active_count += 1;&#10;    } else {&#10;        border_objects[i].setLineWidth(2);&#10;        border_objects[i].setLineColor(&quot;gray&quot;);&#10;    }&#10;}&#10;for (var j, _pj_c = 0, _pj_a = util.range(active_count, NUM_ITEMS_TO_SELECT), _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&#10;    j = _pj_a[_pj_c];&#10;    center_overlays[j].setOpacity(0.0);&#10;}&#10;" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="End JS Routine" val="" valType="extendedCode" updates="constant" plugin="None"/>
                <Param name="End JS Experiment" val="" valType="extendedCode" updates="constant" plugin="None"/>
            </CodeComponent>
        </Routine>
    </Routines>
    <Flow>
        <Routine name="task_trial"/>
    </Flow>
</PsychoPy2experiment>