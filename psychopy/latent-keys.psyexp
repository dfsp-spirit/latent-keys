                <Param name="durationEstim" val="" valType="code" updates="None" plugin="None"/>
                <Param name="stopType" val="duration (s)" valType="str" updates="None" plugin="None"/>
                <Param name="color" val="$[1,1,1]" valType="color" updates="constant" plugin="None"/>
                <Param name="colorSpace" val="rgb" valType="str" updates="constant" plugin="None"/>
                <Param name="opacity" val="" valType="num" updates="constant" plugin="None"/>
